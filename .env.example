# Copy to .env (gitignored). start.sh reads these; CLI flags override them.
# Precedence (highest first): CLI flags > .env > .local-recorder.conf > defaults.

# Unpacked extension ID (chrome://extensions, Developer mode -> Load unpacked).
EXTENSION_ID=

# Browser that hosts the extension: chrome | chromium | brave | edge
BROWSER=chrome

# Candidate languages forwarded to the daemon as --languages.
# Comma-separated two-letter codes; omit to use the daemon default (pl,en).
LANGUAGES=pl,en
